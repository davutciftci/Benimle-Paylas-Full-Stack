// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  EXPERT
  ADMIN
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String
  lastName  String
  phone     String?
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expertProfile      Expert?
  appointments       Appointment[]
  reviews            Review[]
  passwordResetToken PasswordResetToken?

  @@map("users")
}

model Expert {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  title           String
  specialty       String[]
  description     String
  fullDescription String?
  image           String?
  experience      String
  education       String?
  languages       String[]
  sessionTypes    String[]
  priceMin        Int      @default(0)
  priceMax        Int      @default(0)
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  availability    Json?
  insurance       String[]
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  appointments Appointment[]
  reviews      Review[]

  @@map("experts")
}

model Appointment {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  expertId    String
  expert      Expert            @relation(fields: [expertId], references: [id], onDelete: Cascade)
  date        DateTime
  startTime   String
  endTime     String
  status      AppointmentStatus @default(PENDING)
  notes       String?
  sessionType String            @default("ONLINE")
  meetingLink String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("appointments")
}

model Review {
  id        String   @id @default(cuid())
  expertId  String
  expert    Expert   @relation(fields: [expertId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userName  String
  rating    Float
  comment   String   @default("")
  createdAt DateTime @default(now())

  @@map("reviews")
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  author      String
  imageUrl    String?
  category    String?
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blog_posts")
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@map("faqs")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model PsychologistApplication {
  id         String            @id @default(cuid())
  name       String
  email      String
  phone      String?
  title      String?
  experience String?
  documents  String?
  status     ApplicationStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@map("psychologist_applications")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}
