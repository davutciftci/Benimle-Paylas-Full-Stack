// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Referans / Lookup Tabloları
model Role {
  id          Int     @id @default(autoincrement())
  name        String  @unique // 'user', 'expert', 'admin'
  description String?
  users       User[]

  @@map("roles")
}

model DegreeType {
  id             Int             @id @default(autoincrement())
  name           String          @unique // 'bachelor', 'master', 'phd'
  description    String?
  expertProfiles ExpertProfile[]

  @@map("degree_types")
}

model AppointmentStatus {
  id           Int           @id @default(autoincrement())
  name         String        @unique // 'pending', 'confirmed', 'cancelled', 'completed', 'no_show'
  description  String?
  appointments Appointment[]

  @@map("appointment_statuses")
}

// Ana Kullanıcı Tablosu
model User {
  id           Int      @id @default(autoincrement())
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  phone        String?  @db.VarChar(20)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  roleId       Int      @map("role_id")
  role         Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  expertProfile      ExpertProfile?
  appointmentsClient Appointment[]       @relation("ClientAppointments")
  reviews            Review[]
  passwordResetToken PasswordResetToken?
  contactMessages    ContactMessage[]

  @@index([email])
  @@index([roleId])
  @@map("users")
}

// Uzman Profili Tablosu
model ExpertProfile {
  id                Int         @id @default(autoincrement())
  userId            Int         @unique @map("user_id")
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio               String?     @db.Text
  university        String?     @db.VarChar(255)
  fieldOfStudy      String?     @map("field_of_study") @db.VarChar(255)
  degreeId          Int?        @map("degree_id")
  degree            DegreeType? @relation(fields: [degreeId], references: [id], onDelete: Restrict)
  graduationYear    Int?        @map("graduation_year") @db.SmallInt
  licenseNumber     String?     @unique @map("license_number") @db.VarChar(100)
  yearsOfExperience Int?        @map("years_of_experience") @db.SmallInt
  profilePhotoUrl   String?     @map("profile_photo_url") @db.VarChar(255)
  isVerified        Boolean     @default(false) @map("is_verified")
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  appointments Appointment[] @relation("ExpertAppointments")
  reviews      Review[]

  @@index([degreeId])
  @@map("expert_profiles")
}

// Randevular Tablosu
model Appointment {
  id              Int               @id @default(autoincrement())
  clientId        Int               @map("client_id")
  client          User              @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Cascade)
  expertId        Int               @map("expert_id")
  expert          ExpertProfile     @relation("ExpertAppointments", fields: [expertId], references: [id], onDelete: Cascade)
  scheduledAt     DateTime          @map("scheduled_at") @db.Timestamptz
  durationMinutes Int               @default(50) @map("duration_minutes") @db.SmallInt
  statusId        Int               @map("status_id")
  status          AppointmentStatus @relation(fields: [statusId], references: [id], onDelete: Restrict)
  notes           String?           @db.Text
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([clientId])
  @@index([expertId])
  @@index([statusId])
  @@index([scheduledAt])
  @@map("appointments")
}

// Diğer Gerekli Tablolar
model Review {
  id        Int           @id @default(autoincrement())
  expertId  Int           @map("expert_id")
  expert    ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)
  userId    Int           @map("user_id")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userName  String        @map("user_name")
  rating    Float
  comment   String        @default("") @db.Text
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz

  @@map("reviews")
}

model BlogPost {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  content     String   @db.Text
  excerpt     String?  @db.Text
  author      String
  imageUrl    String?  @map("image_url")
  category    String?
  publishedAt DateTime @default(now()) @map("published_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("blog_posts")
}

model FAQ {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String   @db.Text
  category  String?
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("faqs")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  userId    Int?     @map("user_id") // Optional relation if sender is logged in
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("contact_messages")
}

model PsychologistApplication {
  id         Int      @id @default(autoincrement())
  name       String
  email      String
  phone      String?
  title      String?
  experience String?
  documents  String?  @db.Text
  statusName String   @default("pending") @map("status_name") // Basic strings fallback for unassociated applications "pending", "approved", "rejected"
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("psychologist_applications")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("password_reset_tokens")
}
