generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
  expert

  @@map("user_roles")
}

model DegreeType {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  description    String?
  expertProfiles ExpertProfile[]

  @@map("degree_types")
}

model AppointmentStatus {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  description  String?
  appointments Appointment[]

  @@map("appointment_statuses")
}

model Title {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  expertProfiles ExpertProfile[]

  @@map("titles")
}

model Specialty {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  expertProfiles ExpertProfile[] @relation("ExpertSpecialties")

  @@map("specialties")
}

model TherapeuticApproach {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  expertProfiles ExpertProfile[] @relation("ExpertApproaches")

  @@map("therapeutic_approaches")
}

model Seminar {
  id              Int           @id @default(autoincrement())
  title           String
  description     String?
  date            DateTime?     @db.Date
  expertProfileId Int           @map("expert_profile_id")
  expertProfile   ExpertProfile @relation(fields: [expertProfileId], references: [id], onDelete: Cascade)

  @@index([expertProfileId])
  @@map("seminars")
}

model User {
  email              String              @unique @db.VarChar(255)
  phone              String?             @db.VarChar(20)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  firstName          String              @map("first_name") @db.VarChar(100)
  isActive           Boolean             @default(true) @map("is_active")
  lastName           String              @map("last_name") @db.VarChar(100)
  passwordHash       String              @map("password_hash") @db.VarChar(255)
  role               UserRole            @default(user) @map("role")
  updatedAt          DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  id                 Int                 @id @default(autoincrement())
  appointmentsClient Appointment[]       @relation("ClientAppointments")
  contactMessages    ContactMessage[]
  expertProfile      ExpertProfile?
  passwordResetToken PasswordResetToken?
  reviews            Review[]

  @@index([email])
  @@map("users")
}

model ExpertProfile {
  id                    Int                   @id @default(autoincrement())
  userId                Int                   @unique @map("user_id")
  bio                   String?
  university            String?               @db.VarChar(255)
  fieldOfStudy          String?               @map("field_of_study") @db.VarChar(255)
  degreeId              Int?                  @map("degree_id")
  titleId               Int?                  @map("title_id")
  graduationYear        Int?                  @map("graduation_year") @db.SmallInt
  licenseNumber         String?               @unique @map("license_number") @db.VarChar(100)
  yearsOfExperience     Int?                  @map("years_of_experience") @db.SmallInt
  profilePhotoUrl       String?               @map("profile_photo_url") @db.VarChar(255)
  price                 Int?                  @map("price")
  isVerified            Boolean               @default(false) @map("is_verified")
  createdAt             DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  workingHours          Json?                 @map("working_hours")
  appointments          Appointment[]         @relation("ExpertAppointments")
  degree                DegreeType?           @relation(fields: [degreeId], references: [id], onDelete: Restrict)
  title                 Title?                @relation(fields: [titleId], references: [id], onDelete: Restrict)
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews               Review[]
  specialties           Specialty[]           @relation("ExpertSpecialties")
  therapeuticApproaches TherapeuticApproach[] @relation("ExpertApproaches")
  seminars              Seminar[]

  @@index([degreeId])
  @@map("expert_profiles")
}

model Appointment {
  notes           String?
  clientId        Int               @map("client_id")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  durationMinutes Int               @default(50) @map("duration_minutes") @db.SmallInt
  expertId        Int               @map("expert_id")
  scheduledAt     DateTime          @map("scheduled_at") @db.Timestamptz(6)
  statusId        Int               @map("status_id")
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  id              Int               @id @default(autoincrement())
  client          User              @relation("ClientAppointments", fields: [clientId], references: [id], onDelete: Cascade)
  expert          ExpertProfile     @relation("ExpertAppointments", fields: [expertId], references: [id], onDelete: Cascade)
  status          AppointmentStatus @relation(fields: [statusId], references: [id])

  @@index([clientId])
  @@index([expertId])
  @@index([statusId])
  @@index([scheduledAt])
  @@map("appointments")
}

model Review {
  rating    Float
  comment   String        @default("")
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  expertId  Int           @map("expert_id")
  userId    Int           @map("user_id")
  userName  String        @map("user_name")
  id        Int           @id @default(autoincrement())
  expert    ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model BlogPost {
  title       String
  slug        String   @unique
  content     String
  excerpt     String?
  author      String
  category    String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  imageUrl    String?  @map("image_url")
  publishedAt DateTime @default(now()) @map("published_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  id          Int      @id @default(autoincrement())

  @@map("blog_posts")
}

model FAQ {
  question  String
  answer    String
  category  String?
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  id        Int      @id @default(autoincrement())

  @@map("faqs")
}

model ContactMessage {
  name      String
  email     String
  subject   String?
  message   String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  isRead    Boolean  @default(false) @map("is_read")
  userId    Int?     @map("user_id")
  id        Int      @id @default(autoincrement())
  user      User?    @relation(fields: [userId], references: [id])

  @@map("contact_messages")
}

model PsychologistApplication {
  name       String
  email      String
  phone      String?
  title      String?
  experience String?
  documents  String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  statusName String   @default("pending") @map("status_name")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  id         Int      @id @default(autoincrement())

  @@map("psychologist_applications")
}

model PasswordResetToken {
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  userId    Int      @unique @map("user_id")
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model SignLanguageWord {
  word      String   @unique @db.VarChar(100)
  videoUrl  String?  @map("video_url") @db.VarChar(500)
  category  String?  @db.VarChar(50)
  hasVideo  Boolean  @default(false) @map("has_video")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  id        Int      @id @default(autoincrement())

  @@index([word])
  @@map("sign_language_words")
}
